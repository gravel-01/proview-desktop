{
  "name": "proview-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Electron shell for ProView AI Interviewer",
  "main": "electron/main.cjs",
  "scripts": {
    "build:frontend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-frontend.ps1",
    "build:backend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-backend.ps1",
    "build:frontend:mac": "bash ./scripts/build-frontend.sh",
    "build:backend:mac": "bash ./scripts/build-backend-macos.sh",
    "pack": "npm run build:frontend && npm run build:backend && powershell -ExecutionPolicy Bypass -File .\\scripts\\package-app.ps1 --dir",
    "dist": "npm run build:frontend && npm run build:backend && powershell -ExecutionPolicy Bypass -File .\\scripts\\package-app.ps1 --win nsis portable",
    "dist:mac": "npm run build:frontend:mac && npm run build:backend:mac && bash ./scripts/package-app-macos.sh"
  },
  "devDependencies": {
    "electron": "37.2.6",
    "electron-builder": "^26.1.0"
  },
  "build": {
    "appId": "com.proview.desktop",
    "productName": "ProView AI Interviewer",
    "electronVersion": "37.2.6",
    "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "publish": null,
    "files": [
      "electron/**/*",
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "build/backend/proview-backend",
        "to": "backend/proview-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-Mac-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  }
}
