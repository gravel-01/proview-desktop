# Example backend .env file
# Copy this file to backend/.env and fill in real values.

# =========================
# LLM / Model Providers
# Configure at least one provider.
# =========================

# Optional custom gateway / proxy used by some local setups.
# The current backend main flow does not require this.
# ANY_MODEL_ENDPOINT=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

ERNIE_API_KEY=
ERNIE_BASE_URL=https://aistudio.baidu.com/llm/lmapi/v3

# Optional search tools
# SERPER_API_KEY is used by backend/core/tools/google_search.py.
# TAVILY_API_KEY is reserved for optional external tooling / future use.
SERPER_API_KEY=
# TAVILY_API_KEY=


# =========================
# Local Dev Server
# Override when localhost:5000 is occupied.
# =========================
PROVIEW_API_PORT=5000
# PROVIEW_API_HOST=127.0.0.1


# =========================
# OCR / Speech
# =========================
PADDLEOCR_API_URL=https://your-paddle-ocr.example/layout-parsing
PADDLE_OCR_TOKEN=

BAIDU_APP_KEY=
BAIDU_SECRET_KEY=


# =========================
# Runtime Storage
# Local PostgreSQL is now the default target.
# The backend prefers BACKEND_DB_URL / DATABASE_URL / SUPABASE_DB_URL first.
# Business tables are auto-created by DirectDataStore on startup.
# Run docs/database/LOCAL_POSTGRES_INIT.sql once to initialize pgvector + rag schema.
# =========================

# Recommended local PostgreSQL DSN
BACKEND_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/proview_local
# DATABASE_URL=
# SUPABASE_DB_URL=

# Legacy Supabase HTTP compatibility
# Keep these empty for local PostgreSQL deployments.
# If BACKEND_DB_URL is also set, backend now prefers the direct DB path.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# Optional single-file SQLite dev mode
# Leave BACKEND_DB_URL empty, then set:
# PROVIEW_SQLITE_DB_PATH=../database/interviews.db
# Leave the next two unset to share the same SQLite file above:
# PROVIEW_CAREER_DB_PATH=
# PROVIEW_SESSION_TOKEN_DB_PATH=


# =========================
# Local Embedding Runtime
# Used by backend RAG retrieval to build query embeddings locally.
# If the model files do not exist, the app degrades gracefully.
# =========================
LOCAL_EMBEDDING_MODEL_DIR=../start-data-service/onnx_models/all-MiniLM-L6-v2/onnx
LOCAL_EMBEDDING_MAX_LENGTH=256


# =========================
# Optional remote embedding config
# Not required by the current backend main runtime.
# Keep these only if you use import scripts or external embedding workflows.
# =========================
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=384
# EMBEDDING_BATCH_SIZE=32

# langfuse config
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_BASE_URL="https://cloud.langfuse.com"